@startuml
skinparam Shadowing false
skinparam MonospacedFont "Courier"

title EuroRoute-IO: PolyAPI eu1 Sovereign Integration

actor "User" as User

box "AWS Cloud (Stateless / DE)" #FFF3E0
    participant "API Gateway" as AGW
    participant "Lambda (eu-central-1)" as Lambda
end box

box "PolyAPI Cloud (eu1.polyapi.io)" #F3E5F5
    participant "PolyAPI eu1 Control Plane" as Control
    participant "PolyAPI eu1 Execution" as Exec
end box

box "OVHcloud (Sovereign Data Fortress / FR)" #E8F5E9
    participant "OVH KMS" as KMS
    database "Managed PostgreSQL" as DB
    database "Managed Redis" as Cache
end box

box "External APIs" #ECEFF1
    collections "3rd-Party APIs" as APIs
end box

' Flow Logic
User -> AGW : 1. Request
AGW -> Lambda : 2. Trigger
Lambda -> KMS : 3. Decrypt Keys
KMS -> Lambda : 4. Sovereign Keys

' Orchestration moves to PolyAPI eu1
Lambda -> Exec : 5. Call Unified SDK (eu1)
Exec -> APIs : 6. Concurrent API Calls
APIs -> Exec : 7. Raw Data
Exec -> Exec : 8. Schema Mapping & Transformation

Exec -> Lambda : 9. Unified Response Payload
Lambda -> DB : 10. Save Shipment Data
Lambda -> Cache : 11. Real-time Session Update

Lambda -> User : 12. Final Response
@enduml